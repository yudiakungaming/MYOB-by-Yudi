{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with login status and subscription information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user ID from Firebase Auth"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "User display name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "User registration timestamp"
        }
      },
      "required": ["uid", "email"]
    },
    "Company": {
      "title": "Company",
      "description": "Represents an MYOB company database file",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique company ID"
        },
        "name": {
          "type": "string",
          "description": "Company legal name"
        },
        "address": {
          "type": "string",
          "description": "Company physical address"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Company contact email"
        },
        "fiscalYear": {
          "type": "integer",
          "description": "Current Financial Year (e.g. 2026)"
        },
        "conversionMonth": {
          "type": "integer",
          "description": "The first month of the financial year (1-12)"
        },
        "accountingPeriods": {
          "type": "integer",
          "description": "Number of periods, usually 12 or 13"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the owner who created this company database"
        }
      },
      "required": ["id", "name", "fiscalYear", "conversionMonth", "ownerId"]
    },
    "Account": {
      "title": "Account",
      "description": "A single General Ledger account (Chart of Accounts)",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Account number / code"
        },
        "name": {
          "type": "string",
          "description": "Account name"
        },
        "type": {
          "type": "string",
          "enum": ["Asset", "Liability", "Equity", "Revenue", "Cost Of Sales", "Expense", "Other Income", "Other Expense"],
          "description": "Visual classification category matching MYOB COA tabs"
        },
        "classification": {
          "type": "string",
          "enum": ["Header", "Detail"],
          "description": "Header accounts group detail accounts and cannot receive direct postings"
        },
        "parentCode": {
          "type": "string",
          "description": "Prefix code for nesting accounts in hierarchy"
        },
        "openingBalance": {
          "type": "number",
          "description": "Opening balance of the account for current financial year"
        },
        "currentBalance": {
          "type": "number",
          "description": "Running balance calculation"
        },
        "balanceType": {
          "type": "string",
          "enum": ["Debit", "Credit"],
          "description": "Normal account balance type"
        }
      },
      "required": ["id", "name", "type", "classification", "openingBalance", "currentBalance", "balanceType"]
    },
    "Journal": {
      "title": "Journal",
      "description": "A journal transaction containing one or more debit/credit items",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique journal transaction ID / reference number"
        },
        "referenceNum": {
          "type": "string",
          "description": "Manual reference number, e.g. GJ0001, banking slip card"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Transaction booking date"
        },
        "explanation": {
          "type": "string",
          "description": "Memo describing the batch transaction"
        },
        "source": {
          "type": "string",
          "enum": ["General Journal", "Spend Money", "Receive Money", "Sales Payment", "Purchase Payment"],
          "description": "The MYOB command center origin of the posting"
        },
        "lines": {
          "type": "array",
          "description": "Postings to accounts, matching must sum Debits == Credits"
        },
        "totalAmount": {
          "type": "number",
          "description": "Total Debit (or Credit) sum"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["id", "referenceNum", "date", "explanation", "source", "lines", "totalAmount"]
    },
    "Card": {
      "title": "Card",
      "description": "A contact card in the Card File for a customer, supplier or employee",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique Card ID"
        },
        "type": {
          "type": "string",
          "enum": ["Customer", "Supplier", "Employee"],
          "description": "Card classification"
        },
        "name": {
          "type": "string",
          "description": "Display name"
        },
        "cardIdCode": {
          "type": "string",
          "description": "Unique manual identification code (e.g. CUST-01)"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email"
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number"
        },
        "address": {
          "type": "string",
          "description": "Postal address billing/shipping"
        }
      },
      "required": ["id", "type", "name", "cardIdCode"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User accounts with authenticated privileges"
    },
    "/users/{userId}/companies/{companyId}": {
      "schema": "Company",
      "description": "Active fiscal companies within MYOB"
    },
    "/users/{userId}/companies/{companyId}/accounts/{accountId}": {
      "schema": "Account",
      "description": "Chart of Accounts setup for a particular firm"
    },
    "/users/{userId}/companies/{companyId}/journals/{journalId}": {
      "schema": "Journal",
      "description": "Ledger financial transactions of the company file"
    },
    "/users/{userId}/companies/{companyId}/cards/{cardId}": {
      "schema": "Card",
      "description": "Customers, Suppliers, and Employees contact registry"
    }
  }
}
